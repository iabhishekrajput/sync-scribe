# Postgres — host port 5433 (avoid collision with auth_postgres on 5432)
DATABASE_URL=postgres://syncscribe:syncscribe@localhost:5433/syncscribe?sslmode=disable

# Valkey — host port 6380 (avoid collision with auth_redis on 6379)
REDIS_URL=redis://localhost:6380/0

# OIDC — point at your real OAuth2/OIDC authorization server.
# OIDC_CLIENT_SECRET is empty for public SPA (PKCE only); set for confidential clients.
# OIDC_TOKEN_AUDIENCE: required for Auth0. Without it Auth0 issues an opaque/JWE
#   access token that go-oidc cannot verify. Set to your Auth0 API identifier
#   (Auth0 Dashboard → Applications → APIs → your API → API Audience).
#   Leave empty for Dex, Keycloak, or any IdP that issues signed JWTs by default.
OIDC_ISSUER_URL=https://your-auth-server.example.com
OIDC_CLIENT_ID=syncscribe-web
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:8080/auth/callback
OIDC_TOKEN_AUDIENCE=

# API
API_PORT=8080
API_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000

# Cookies — COOKIE_SECRET MUST be 32+ random bytes (hex preferred).
# Generate: openssl rand -hex 32
COOKIE_SECRET=replace-with-output-of-openssl-rand-hex-32
COOKIE_SECURE=false

# Web (Next.js)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8080
NEXT_PUBLIC_OIDC_PROVIDER_NAME=OIDC

# SMTP (Mailpit on host port 1026, UI on 8026)
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_FROM=noreply@syncscribe.local

# Observability
LOG_LEVEL=debug
