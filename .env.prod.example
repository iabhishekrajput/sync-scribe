# Copy to .env.prod and fill in real values. Never commit the populated file.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# --- Database (postgres host on data_network) ---
POSTGRES_USER=syncscribe
POSTGRES_PASSWORD=change-me
POSTGRES_DB=syncscribe

# --- OIDC ---
# Issuer URL of your authorization server (e.g. Auth0, Keycloak, Authentik).
OIDC_ISSUER_URL=https://your-idp.example.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Auth0 requires an audience; leave empty for generic OIDC.
OIDC_TOKEN_AUDIENCE=

# --- Cookies ---
# 32+ random bytes. Generate with: openssl rand -hex 32
COOKIE_SECRET=replace-with-openssl-rand-hex-32

# --- SMTP (invites) ---
# Leave SMTP_USERNAME empty for unauthenticated relays (mailpit in dev).
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=noreply@anekdote.in
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Admin / logging ---
ADMIN_SECRET=
LOG_LEVEL=info

# --- Misc ---
TZ=UTC

# --- Cloudflare Tunnel ---
# Token from Cloudflare Zero Trust → Networks → Tunnels.
CLOUDFLARED_TUNNEL_TOKEN=
