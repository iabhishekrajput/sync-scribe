{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@syncscribe/proto": ["../proto/src/index.ts"],
      "yjs": ["../../apps/web/node_modules/yjs"],
      "y-protocols/*": ["../../apps/web/node_modules/y-protocols/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["src/**/*"]
}
